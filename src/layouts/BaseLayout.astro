---
import '../index.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Jay's space", 
  description = "Personal website of Jay Lok. Showcasing software engineering projects, technical writing, and tools." 
} = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-05TYX9YCED"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-05TYX9YCED');
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
