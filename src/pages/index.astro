---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import App from '../App.jsx';

const rawPosts = await getCollection('posts');
const rawProjects = await getCollection('projects');

// Map collections to match original schema
const postsData = rawPosts.map(post => ({
  id: post.id,
  title: post.data.title,
  excerpt: post.data.excerpt,
  date: post.data.date,
  readTime: post.data.readTime,
  content: post.body,
  tags: post.data.tags || [],
}));

const projectsData = rawProjects.map(proj => ({
  id: proj.id,
  title: proj.data.title,
  description: proj.data.description,
  tags: proj.data.tags,
  links: proj.data.links || {},
  featured: proj.data.featured,
}));
---

<BaseLayout>
  <App posts={postsData} projects={projectsData} client:load />
</BaseLayout>
